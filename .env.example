# --- LLM provider ---
GOOGLE_API_KEY=

# --- Transport MCPs (clone each repo locally, then set its path + key) ---

# Flights — github.com/ravinahp/flights-mcp  (uv project, Duffel API)
#   git clone https://github.com/ravinahp/flights-mcp
#   cd flights-mcp && uv sync
FLIGHTS_MCP_PATH=
DUFFEL_API_KEY_LIVE=

# Trains — local sncf-mcp (our own minimal client; replaces broken
#                          Kryzo/mcp-sncf with a direct SNCF /places +
#                          /journeys integration that resolves any French
#                          or cross-border station dynamically)
#   The server lives at D:\MCP-servers\sncf-mcp\sncf_server.py and ships
#   with this project. Just point SNCF_MCP_PATH at its folder and
#   `pip install -r requirements.txt` inside it.
# Sign up for the free SNCF API token: https://numerique.sncf.com/startup/api
SNCF_MCP_PATH=
SNCF_API_TOKEN=

# Buses — github.com/vlad-ds/flixbus-mcp  (uv project, RapidAPI FlixBus)
#   git clone https://github.com/vlad-ds/flixbus-mcp
#   cd flixbus-mcp && uv sync
# Sign up: https://rapidapi.com/3b-data-3b-data-default/api/flixbus2/
FLIXBUS_MCP_PATH=
RAPID_API_KEY=

# --- Optional add-on MCPs ---
BRAVE_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- LangSmith (observability + eval) ---
# Sign up free: https://smith.langchain.com  → Settings → API Keys
# Once these are set, every agent run uploads a trace automatically.
# View at https://smith.langchain.com/projects/<LANGSMITH_PROJECT>
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=travel-agent
# Optional — point to a self-hosted LangSmith instance:
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Override the Python interpreter used to launch mcp-sncf ---
# Defaults to `py` on Windows, `python3` elsewhere. Set this if those
# interpreters don't have mcp-sncf's deps installed.
# MCP_PYTHON=C:\path\to\python.exe
